# =============================================================================
# Shipwright Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values you need.
# .env.local is gitignored and will never be committed.
#
# All variables are optional — Shipwright works without any of them.
# Features are enabled/disabled based on which keys are present.
# =============================================================================

# --- External Plan Review (shipwright-plan) ---
# Option A: OpenRouter (recommended — one key for both review models)
# OPENROUTER_API_KEY=sk-or-...

# Option B: Direct API keys (alternative to OpenRouter)
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...          # alias for GEMINI_API_KEY
# OPENAI_API_KEY=sk-...

# --- Security Scanning (shipwright-security) ---
# Get credentials at: https://app.aikido.dev/settings/integrations/api/aikido/rest
# AIKIDO_CLIENT_ID=...
# AIKIDO_CLIENT_SECRET=...

# --- Deployment (shipwright-deploy) ---
# These can also be set as OS environment variables in your shell profile.
# JELASTIC_TOKEN=...
# SUPABASE_ACCESS_TOKEN=sbp_...
