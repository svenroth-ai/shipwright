# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Windows env-var-resolution failure dir: uv on Windows without
# SystemDrive/LOCALAPPDATA set creates a literal "%SystemDrive%"
# directory under CWD as it tries to compute its data dir path.
# Defensive ignore — the round-trip test in
# plugins/shipwright-iterate/tests/test_hooks_json_registration.py
# has been hardened to forward these vars so the dir should not
# reappear, but belt+suspenders.
%SystemDrive%/
dist/
/build/
.eggs/
*.egg
.venv/
venv/

# Node
node_modules/
.next/
out/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test / Coverage
.coverage
htmlcov/
.pytest_cache/
coverage/
playwright-report/
test-results/
e2e-results.json

# Vite
.vite/

# Shipwright runtime artifacts (generated in target projects, not in this repo).
# Self-adoption 2026-05-02: the framework adopts itself, so root-level
# configs + events.jsonl are now also tracked. Nested target-project copies
# (e.g. tests/fixtures/<project>/shipwright_*_config.json) stay ignored.
shipwright_*_config.json
# Exception: the template under shared/templates/ MUST be tracked — it's the
# canonical version copied into every adopted/new project.
!shared/templates/shipwright_*_config.json
# Exception: root-level configs from the framework's own self-adoption.
!/shipwright_*_config.json
shipwright_events.jsonl
shipwright_events.jsonl.lock
# Exception: root-level event log from the framework's own self-adoption.
!/shipwright_events.jsonl
# Canonical agent_docs home is .shipwright/agent_docs/.
# legacy path - do not remove. Sub-Iterate F of agent_docs migration (2026-04-28).
# Anchored to root since 2026-05-02 self-adoption to allow .shipwright/agent_docs/.
# See docs/migrations/.shipwright-agent_docs-relocation.md.
/agent_docs/
# Canonical designs home is .shipwright/designs/.
# legacy path - do not remove. Sub-Iterate F of designs migration (2026-04-27).
# Anchored to root since 2026-05-02 self-adoption to allow .shipwright/designs/.
# See docs/migrations/.shipwright-designs-relocation.md.
/designs/
# Canonical planning home is .shipwright/planning/.
# legacy path - do not remove. Sub-Iterate F (2026-04-27).
# Kept as a safety net against re-tracked legacy files.
# Anchored to root since 2026-05-02 self-adoption to allow .shipwright/planning/.
# See docs/migrations/.shipwright-relocation.md.
/planning/
# Canonical tool-call counter is .shipwright/toolcall_count.
# legacy path - do not remove. Renamed 2026-04-29 (drive-by, no migration).
.shipwright_toolcall_count
# Canonical compliance home is .shipwright/compliance/.
# legacy path - do not remove. Sub-Iterate F of compliance migration (2026-04-29).
# Anchored to root since 2026-05-02 self-adoption to allow .shipwright/compliance/.
# See docs/migrations/.shipwright-compliance-relocation.md.
/compliance/

# UV
.uv/

# Specifications (internal only)
Spec/
.companion-ref/

# Iterate 12.0 helper lock files (append_changelog_entry, append_phase_history)
*.md.lock
*.json.lock

# Git worktrees (per Shipwright parallel-iterate convention — see /shipwright-iterate B1a)
.worktrees/

# Shipwright self-adoption (2026-05-02): the framework adopts itself.
# The canonical .shipwright/ artifact homes (agent_docs/, planning/,
# compliance/, designs/, adopt/<snapshots>) are tracked. Transient subdirs
# (scratch, reviews, security reports, tmp, adopt/backups) stay ignored
# via explicit exclusion of those specific subpaths — git cannot re-include
# files inside an excluded parent, so we invert the rule.
/.shipwright/external-review-temp/
/.shipwright/reviews/
/.shipwright/securityreports/
/.shipwright/tmp/
/.shipwright/adopt/backups/
