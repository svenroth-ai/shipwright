/**
 * DevErrorOverlay — runtime-error modal for dev mode only.
 *
 * Replit-pattern adopt (Sub-Iterate A): when an unhandled error or promise
 * rejection happens in the browser during development, the developer should
 * see it immediately as a modal overlay rather than have to open the console.
 *
 * Renders nothing in production (gated on `import.meta.env.DEV`).
 *
 * Usage (in your app entry, e.g. client/src/main.tsx):
 *
 *     import DevErrorOverlay from './DevErrorOverlay';
 *     // ...
 *     createRoot(rootEl).render(
 *       <>
 *         <App />
 *         <DevErrorOverlay />
 *       </>
 *     );
 *
 * Errors are still re-logged to the console so devtools breakpoints and
 * source-map traces continue to work — the overlay is purely UI on top.
 *
 * Requires the automatic JSX runtime (`tsconfig.json` → `"jsx": "react-jsx"`,
 * which is the default with `@vitejs/plugin-react`). Projects pinned to the
 * classic runtime (`"jsx": "react"`) need to add `import React from 'react'`.
 */
import { useEffect, useState } from 'react';

// Captured errors are appended unbounded; cap at MAX_CAPTURED to prevent
// memory growth in noisy apps. The overlay only ever displays the latest one
// anyway, so older entries serve only as scrollback inside this session.
const MAX_CAPTURED = 50;

type CapturedError = {
  message: string;
  stack?: string;
  source?: string;
  at: number;
};

export default function DevErrorOverlay() {
  const [errors, setErrors] = useState<CapturedError[]>([]);
  const [hidden, setHidden] = useState(false);

  useEffect(() => {
    if (!import.meta.env.DEV) return;

    const onError = (event: ErrorEvent) => {
      const captured: CapturedError = {
        message: event.message || String(event.error ?? 'Unknown error'),
        stack: event.error?.stack,
        source: event.filename
          ? `${event.filename}:${event.lineno ?? '?'}:${event.colno ?? '?'}`
          : undefined,
        at: Date.now(),
      };
      // Re-log so devtools still see it (overlay does not swallow).
      console.error('[DevErrorOverlay] window error:', event.error ?? event.message);
      setErrors((prev) => [...prev.slice(-(MAX_CAPTURED - 1)), captured]);
      setHidden(false);
    };

    const onRejection = (event: PromiseRejectionEvent) => {
      const reason = event.reason;
      const captured: CapturedError = {
        message:
          reason instanceof Error
            ? reason.message
            : typeof reason === 'string'
              ? reason
              : 'Unhandled promise rejection',
        stack: reason instanceof Error ? reason.stack : undefined,
        source: 'unhandledrejection',
        at: Date.now(),
      };
      console.error('[DevErrorOverlay] unhandled rejection:', reason);
      setErrors((prev) => [...prev.slice(-(MAX_CAPTURED - 1)), captured]);
      setHidden(false);
    };

    window.addEventListener('error', onError);
    window.addEventListener('unhandledrejection', onRejection);
    return () => {
      window.removeEventListener('error', onError);
      window.removeEventListener('unhandledrejection', onRejection);
    };
  }, []);

  if (!import.meta.env.DEV || hidden || errors.length === 0) return null;

  const latest = errors[errors.length - 1];
  return (
    <div
      role="alertdialog"
      aria-label="Runtime error"
      style={{
        position: 'fixed',
        inset: 0,
        background: 'rgba(0, 0, 0, 0.55)',
        zIndex: 2147483647,
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        padding: '32px',
        fontFamily:
          'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace',
      }}
    >
      <div
        style={{
          maxWidth: '900px',
          width: '100%',
          maxHeight: '80vh',
          overflow: 'auto',
          background: '#1e1e1e',
          color: '#f5f5f5',
          border: '1px solid #c0392b',
          borderRadius: '6px',
          padding: '20px',
          boxShadow: '0 12px 48px rgba(0, 0, 0, 0.5)',
        }}
      >
        <div
          style={{
            display: 'flex',
            justifyContent: 'space-between',
            alignItems: 'baseline',
            marginBottom: '12px',
          }}
        >
          <strong style={{ color: '#ff6b6b', fontSize: '14px' }}>
            Runtime error ({errors.length}) — DevErrorOverlay
          </strong>
          <button
            onClick={() => setHidden(true)}
            style={{
              background: 'transparent',
              border: '1px solid #888',
              color: '#f5f5f5',
              padding: '4px 10px',
              borderRadius: '4px',
              cursor: 'pointer',
              fontFamily: 'inherit',
              fontSize: '12px',
            }}
          >
            Dismiss
          </button>
        </div>
        <div style={{ fontSize: '14px', marginBottom: '8px' }}>{latest.message}</div>
        {latest.source && (
          <div style={{ fontSize: '11px', color: '#9e9e9e', marginBottom: '12px' }}>
            {latest.source}
          </div>
        )}
        {latest.stack && (
          <pre
            style={{
              fontSize: '11px',
              lineHeight: 1.5,
              margin: 0,
              whiteSpace: 'pre-wrap',
              wordBreak: 'break-word',
              color: '#dcdcdc',
            }}
          >
            {latest.stack}
          </pre>
        )}
      </div>
    </div>
  );
}
