# Integration Test Environment
# MUST point to local Supabase only — URL safety check enforced at runtime
#
# Get these values from `supabase start` output:
#   API URL:   http://127.0.0.1:54321
#   anon key:  eyJ...
#   service_role key: eyJ...

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase start output>
SUPABASE_SERVICE_ROLE_KEY=<from supabase start output>

# Test user credentials — create these users in your local Supabase
# or let the integration test helpers create them automatically
TEST_ADMIN_EMAIL=test-admin@integration.local
TEST_ADMIN_PASSWORD=TestAdminPass123!
TEST_MEMBER_EMAIL=test-member@integration.local
TEST_MEMBER_PASSWORD=TestMemberPass123!
