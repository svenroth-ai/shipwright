{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "uv run ${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/capture_session_id.py"
        },
        {
          "type": "command",
          "command": "uv run ${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/check_drift.py"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": {"tools": ["Bash"]},
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/validate_command.sh"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": {"tools": ["Write", "Edit"]},
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/check_destructive_migration.sh"
        },
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/check_secrets.sh"
        },
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/check_file_size.sh"
        }
      ]
    },
    {
      "hooks": [
        {
          "type": "command",
          "command": "uv run ${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/track_tool_calls.py"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "uv run ${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/audit_phase_quality_on_stop.py"
        },
        {
          "type": "command",
          "command": "uv run ${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/generate_handoff_on_stop.py"
        },
        {
          "type": "command",
          "command": "uv run ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/check_documentation.py"
        },
        {
          "type": "command",
          "command": "uv run ${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/write_terminal_marker.py"
        }
      ]
    }
  ]
}
