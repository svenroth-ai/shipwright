{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/ensure_shared_cache.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/capture_session_id.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/check_drift.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/check_artifact_drift.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/import_github_findings.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/session_start_using_shipwright.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/suggest_iterate.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/iterate_stop_finalize.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/audit_phase_quality_on_stop.py\""
          },
          {
            "type": "command",
            "command": "uv run --with pyyaml \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/audit_compliance_on_stop.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/write_terminal_marker.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/aggregate_triage_on_stop.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/bloat_gate_on_stop.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/plugin_sync_reminder_on_stop.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/check_file_size.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/../../shared/scripts/hooks/mark_plugin_edit.py\""
          }
        ]
      }
    ]
  }
}
