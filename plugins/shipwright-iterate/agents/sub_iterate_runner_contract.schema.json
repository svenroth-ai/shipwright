{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sub-iterate-runner-result",
  "title": "Sub-Iterate Runner Result Contract",
  "description": "JSON schema for the result returned by sub-iterate-runner subagent. Used by the campaign loop to verify subagent output.",
  "oneOf": [
    { "$ref": "#/$defs/success" },
    { "$ref": "#/$defs/failure" },
    { "$ref": "#/$defs/escalated" }
  ],
  "$defs": {
    "success": {
      "type": "object",
      "required": ["sub_iterate_id", "status", "commit", "branch", "tests_passed", "tests_total"],
      "properties": {
        "sub_iterate_id": { "type": "string" },
        "status": { "type": "string", "const": "complete" },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "branch": { "type": "string" },
        "tests_passed": { "type": "integer", "minimum": 0 },
        "tests_total": { "type": "integer", "minimum": 0 },
        "complexity": { "type": "string", "enum": ["trivial", "small", "medium"] },
        "changelog_bullet": { "type": "string" },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "rationale"],
            "properties": {
              "title": { "type": "string" },
              "rationale": { "type": "string" }
            }
          }
        },
        "adr": { "type": "string" },
        "reviews": {
          "type": "object",
          "description": "Review-cascade record per ADR-029. Optional for backwards-compat with pre-ADR-029 result.json files; required for runners under the post-ADR-029 contract.",
          "properties": {
            "plan": {
              "type": "object",
              "description": "External Plan Review (Step 3.5 of sub-iterate-runner contract). Maps to references/iteration-planning.md Step 4.",
              "required": ["status"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "completed",
                    "skipped_complexity_below_threshold",
                    "skipped_user_opt_out",
                    "skipped_config_disabled",
                    "missing_keys"
                  ]
                },
                "provider": { "type": ["string", "null"] },
                "findings_count": { "type": "integer", "minimum": 0 },
                "reason": { "type": "string" }
              }
            },
            "self_review": {
              "type": "object",
              "description": "Self-Review (Step 3.6 of sub-iterate-runner contract, post-ADR-029 follow-up). Mandatory at every complexity. Maps to references/iteration-reviews.md 7-item Self-Review Checklist (item 7 'Affected Boundaries' from ADR-024).",
              "required": ["status"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["completed"]
                },
                "items_failed": { "type": "integer", "minimum": 0, "maximum": 7 },
                "items_passed": { "type": "integer", "minimum": 0, "maximum": 7 },
                "reason": { "type": "string" }
              }
            },
            "code": {
              "type": "object",
              "description": "Internal code-reviewer subagent (Step 3.7a). Runner has no Agent tool, so the subagent is delegated to the orchestrator (campaign mode) or to the parent SKILL.md lifecycle (standalone iterate mode).",
              "required": ["status"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "completed",
                    "delegated_to_orchestrator",
                    "delegated_to_skill",
                    "skipped_diff_below_threshold"
                  ]
                },
                "findings_count": { "type": "integer", "minimum": 0 },
                "reason": { "type": "string" }
              }
            },
            "external_code": {
              "type": "object",
              "description": "External LLM code review cascade (Step 3.7b). Maps to references/iteration-reviews.md 'External Code-Review Cascade'.",
              "required": ["status"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "completed",
                    "skipped_diff_below_threshold",
                    "skipped_user_opt_out",
                    "skipped_config_disabled",
                    "missing_keys"
                  ]
                },
                "provider": { "type": ["string", "null"] },
                "findings_count": { "type": "integer", "minimum": 0 },
                "reason": { "type": "string" }
              }
            },
            "confidence_calibration": {
              "type": "object",
              "description": "Confidence Calibration (Step 3.8 of sub-iterate-runner contract, post-ADR-029 follow-up). Empirical-probe phase mirroring SKILL.md Step 7.5 + references/confidence-anti-patterns.md asymptote heuristic. Mandatory at medium+ OR when touches_io_boundary is set OR when the user/orchestrator explicitly invokes a calibration probe (e.g. 'are you confident?').",
              "required": ["status"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "completed",
                    "skipped_complexity_and_no_io_boundary"
                  ]
                },
                "probes_run": { "type": "integer", "minimum": 0 },
                "probes_with_findings": { "type": "integer", "minimum": 0 },
                "asymptote_reached": { "type": "boolean" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "failure": {
      "type": "object",
      "required": ["sub_iterate_id", "status", "error"],
      "properties": {
        "sub_iterate_id": { "type": "string" },
        "status": { "type": "string", "const": "failed" },
        "error": { "type": "string" },
        "partial_commit": { "type": ["string", "null"] },
        "tests_passed": { "type": "integer", "minimum": 0 },
        "tests_total": { "type": "integer", "minimum": 0 },
        "debug_log": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["attempt", "root_cause", "result"],
            "properties": {
              "attempt": { "type": "integer", "minimum": 1 },
              "root_cause": { "type": "string" },
              "result": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "escalated": {
      "type": "object",
      "required": ["sub_iterate_id", "status", "reason"],
      "properties": {
        "sub_iterate_id": { "type": "string" },
        "status": { "type": "string", "const": "escalated" },
        "reason": { "type": "string" },
        "detected_complexity": { "type": "string", "enum": ["large"] },
        "partial_commit": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  }
}
